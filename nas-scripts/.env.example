# Copy to /opt/nas-backup-monitor/.env and protect it:
# chmod 600 /opt/nas-backup-monitor/.env

# Identity shown in the monitoring API. Keep this manual because Kopia's
# source.host may be a container hostname, not the real NAS name.
NAS_ID=synology-ds1522

# Existing Kopia Server container. The reporter reads all sources from
# `kopia snapshot list --json`; Kopia still owns backup schedules/policies.
KOPIA_CONTAINER_NAME=kopia-server

# Central backup-monitor API and service account.
API_URL=http://192.168.24.6:8000/api
SERVICE_USERNAME=nas-synology
SERVICE_PASSWORD_FILE=/opt/nas-backup-monitor/secrets/service.password
