# ============================================================
# Backup Monitor — Environment Example
# Copy to .env: cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=my_db_user
POSTGRES_PASSWORD=my_db_password
POSTGRES_DB=my_database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port mapping (change if 5432 is taken by a local Postgres)
POSTGRES_HOST_PORT=5433

# Full SQLAlchemy URL (used by API). Host = docker service name "postgres".
# IMPORTANT: Keep this in sync with the credentials above.
DATABASE_URL=postgresql+psycopg://my_db_user:my_db_password@postgres:5432/my_database

# --- JWT / Security ---
# CHANGE THIS in real deployment. Generate: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=backup-monitor-api
JWT_AUDIENCE=backup-monitor-clients

# --- API ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Host-side port mapping for API.
API_HOST_PORT=8000
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000
AUTO_SEED=true
REPORTS_DIR=/app/generated_reports
APP_TIMEZONE=Asia/Jakarta

# --- Web Dashboard (build-time) ---
# Host-side port mapping for the Nginx dashboard.
WEB_HOST_PORT=80
# Base URL the browser uses to reach the API (for local dev mode)
VITE_API_BASE_URL=http://localhost:8000/api

# --- Collector Configuration ---
COLLECTOR_USERNAME=my_collector_user
COLLECTOR_PASSWORD=my_collector_password
COLLECTOR_INTERVAL_SECONDS=60
USE_MOCK_METRICS=true

# --- Monitored Targets ---
# Centralized SNMP exporter endpoint. Leave empty only for legacy per-NAS exporter mode.
# Production example: http://snmp-exporter.example.lan:9116/snmp
SNMP_EXPORTER_URL=http://snmp-exporter.example.lan:9116/snmp
SNMP_DEFAULT_MODULE=if_mib

# Comma-separated NAS targets.
# Preferred format: source_id|ip_address|snmp_exporter_module
# Legacy format source_id:ip_address is still accepted, but cannot set module per NAS.
NAS_TARGETS=synology-ds1522|192.168.x.x|synology_nas,wd-pr4100|192.168.x.y|wd_pr4100
CEPH_METRICS_URL=http://192.168.x.z:9283/metrics
